  },
  "dependencies": {
    "@sinclair/typebox": "0.34.47"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.5.7",
      "minGatewayVersion": "2026.5.7"
    }
  }
